# Description: Environment variables for the project

# Postgres
POSTGRES_DB=food-up
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Server
NODE_ENV=development
SERVER_PORT=3000
ORM_SYNC=true

# Web
WEB_PORT=5000
VITE_API_HOST=http://localhost:3000/api

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Notifications
WEB_APP_URL=http://localhost:5000
MAIL_FROM=noreply@food-up.local