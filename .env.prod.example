# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=foodup
POSTGRES_USER=foodup
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=3000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

# ── Email ─────────────────────────────────────────────────────────────────────
MAIL_FROM=noreply@yourdomain.com
RESEND_API_KEY=re_change-me

# ── URLs ──────────────────────────────────────────────────────────────────────
# Must match your domain — used for CORS and cookie validation
WEB_APP_URL=https://yourdomain.com

# ── Domain / TLS ──────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
LETSENCRYPT_EMAIL=you@yourdomain.com

# ── Observability ─────────────────────────────────────────────────────────────
GRAFANA_USER=admin
# Generate with: openssl rand -hex 16
GRAFANA_PASSWORD=change-me

# ── Scaling ───────────────────────────────────────────────────────────────────
# Set to number of CPU cores on your server (run: nproc)
APP_REPLICAS=2

# ── pgAdmin ─────────────────────────────────────────────────────────────────── 

PGADMIN_EMAIL=admin@foodup.rs
PGADMIN_PASSWORD=<strong-password>
PGADMIN_DOMAIN=pgadmin.foodup.rs

# ── Grafana ───────────────────────────────────────────────────────────────────

GRAFANA_DOMAIN=grafana.foodup.rs
GRAFANA_USER=admin
GRAFANA_PASSWORD=<strong-password>
