{
  "id": null,
  "uid": "food-up-queues",
  "title": "Food-Up · BullMQ Queues",
  "description": "Job throughput, failure rate, processing duration, and queue depth from bullmq-otel (enableMetrics: true).",
  "tags": ["food-up"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "prometheus_ds",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "options": [],
        "current": {}
      },
      {
        "name": "tempo_ds",
        "type": "datasource",
        "query": "tempo",
        "label": "Tempo",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "options": [],
        "current": {}
      },
      {
        "name": "loki_ds",
        "type": "datasource",
        "query": "loki",
        "label": "Loki",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "options": [],
        "current": {}
      },
      {
        "name": "queue",
        "type": "query",
        "label": "Queue",
        "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
        "query": "label_values(bullmq_jobs_completed_total, queue)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "options": [],
        "current": {}
      }
    ]
  },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Jobs Completed (1 m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(bullmq_jobs_completed_total{queue=~\"$queue\"}[1m]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Jobs Failed (1 m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(bullmq_jobs_failed_total{queue=~\"$queue\"}[1m]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P50 Duration",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by(le) (rate(bullmq_job_duration_bucket{queue=~\"$queue\"}[$__rate_interval])))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P95 Duration",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(bullmq_job_duration_bucket{queue=~\"$queue\"}[$__rate_interval])))",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Throughput by Queue",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(queue) (rate(bullmq_jobs_completed_total{queue=~\"$queue\"}[$__rate_interval]))",
          "legendFormat": "{{queue}} completed"
        },
        {
          "refId": "B",
          "expr": "sum by(queue) (rate(bullmq_jobs_failed_total{queue=~\"$queue\"}[$__rate_interval]))",
          "legendFormat": "{{queue}} failed"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Processing Duration Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by(le, queue) (rate(bullmq_job_duration_bucket{queue=~\"$queue\"}[$__rate_interval])))",
          "legendFormat": "{{queue}} P50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by(le, queue) (rate(bullmq_job_duration_bucket{queue=~\"$queue\"}[$__rate_interval])))",
          "legendFormat": "{{queue}} P95"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Queue Depth by State",
      "description": "Requires bullmq-otel enableMetrics. Tracks waiting, active, delayed, and failed job counts per queue.",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "bullmq_queue_jobs{queue=~\"$queue\"}",
          "legendFormat": "{{queue}} · {{status}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*failed" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*waiting" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*active" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          }
        ]
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Job Logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "${loki_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "{service_name=\"food-up\"} | json | line_format \"{{.msg}}\" |~ \"job:\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
