{
  "id": null,
  "uid": "food-up-node-runtime",
  "title": "Food-Up · Node.js Runtime",
  "description": "Heap memory, event loop delay/utilization, and GC metrics from @opentelemetry/instrumentation-runtime-node. If panels show no data, open Explore → Prometheus → Metrics browser and search 'v8js' or 'nodejs_eventloop' to confirm metric names for your OTel SDK version.",
  "tags": ["food-up"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "graphTooltip": 1,
  "templating": {
    "list": [
      {
        "name": "prometheus_ds",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "options": [],
        "current": {}
      }
    ]
  },
  "annotations": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Heap Used",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(v8js_memory_heap_used_bytes)",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200000000 },
              { "color": "red", "value": 400000000 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Heap Utilization",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(v8js_memory_heap_used_bytes) / sum(v8js_memory_heap_limit_bytes)",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Event Loop P99 Delay",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_eventloop_delay_p99_seconds * 1000",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Event Loop Utilization",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_eventloop_utilization_ratio * 100",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Heap Used vs Limit",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(v8js_memory_heap_used_bytes)",
          "legendFormat": "Used"
        },
        {
          "refId": "B",
          "expr": "sum(v8js_memory_heap_limit_bytes)",
          "legendFormat": "Limit"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Limit" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "dash": [8, 4], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Heap Spaces Breakdown",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "v8js_memory_heap_used_bytes",
          "legendFormat": "{{v8js_heap_space_name}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Event Loop Delay",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_eventloop_delay_p50_seconds * 1000",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "nodejs_eventloop_delay_p90_seconds * 1000",
          "legendFormat": "P90"
        },
        {
          "refId": "C",
          "expr": "nodejs_eventloop_delay_p99_seconds * 1000",
          "legendFormat": "P99"
        },
        {
          "refId": "D",
          "expr": "nodejs_eventloop_delay_max_seconds * 1000",
          "legendFormat": "Max"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "dash": [6, 3], "fill": "dash" } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Event Loop Utilization",
      "description": "Fraction of time the event loop is active (not idle). High utilization means the loop has little slack — sustained >0.8 causes latency spikes.",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "nodejs_eventloop_utilization_ratio",
          "legendFormat": "Utilization"
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "GC Time % of Wall Clock",
      "description": "Percentage of wall-clock time spent in garbage collection, by GC type. Sustained >5% is a concern.",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (v8js_gc_type) (rate(v8js_gc_duration_seconds_sum[$__rate_interval]))",
          "legendFormat": "{{v8js_gc_type}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GC Count Rate by Type",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (v8js_gc_type) (rate(v8js_gc_duration_seconds_count[$__rate_interval]))",
          "legendFormat": "{{v8js_gc_type}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 2 }
        },
        "overrides": []
      }
    }
  ]
}
